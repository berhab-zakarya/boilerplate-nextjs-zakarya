        "@types/fs-extra": "^11.0.4",
        "@types/figlet": "^1.5.8",
        "@types/inquirer": "^9.0.7",
        "@types/node": "^20.10.0",
        "@types/semver": "^7.5.6",
        "@types/validate-npm-package-name": "^4.0.2",
        "typescript": "^5.3.2",
        "ts-node": "^10.9.2"
    },
    "engines": {

        "prepublishOnly": "npm run build",
        "dev": "ts-node src/index.ts",
        "start": "node dist/index.js"
    },
    "keywords": [
        "cli",
        "nextjs",
        "next.js",
        "generator",
        "scaffold",
        "typescript",
        "tanstack-query",
        "react-query",
        "axios",
        "feature-based",
        "architecture",
        "boilerplate",
        "create-app"
    ],
    "author": {
        "name": "zakarya",
        "email": "your@email.com",
        "url": "https://github.com/yourusername/zakarya"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/yourusername/zakarya.git"
    },
    "bugs": {
        "url": "https://github.com/yourusername/zakarya/issues"
    },
    "homepage": "https://github.com/yourusername/zakarya#readme",
    "dependencies": {
        "chalk": "^5.3.0",
        "commander": "^11.1.0",
        "execa": "^8.0.1",
        "fs-extra": "^11.2.0",
        "inquirer": "^9.2.12",
        "ora": "^7.0.1",
        "gradient-string": "^2.0.2",
        "figlet": "^1.7.0",

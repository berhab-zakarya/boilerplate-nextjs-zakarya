{
    "name": "zakarya",
    "version": "1.0.0",
    "description": "Production-grade frontend framework generator for Next.js App Router with TanStack Query and feature-based architecture",
    "bin": {
        "zakarya": "./dist/index.js"
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
